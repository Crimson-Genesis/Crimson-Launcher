<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/llOuterContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <LinearLayout
        android:id="@+id/llMessageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/rounded_rect_shade_color"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMedia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible"
            tools:listitem="@layout/item_chat_media" />

        <LinearLayout
            android:id="@+id/llAudioContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvMessage"
            style="@style/TextMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Hello, how can I help you?" />

        <TextView
            android:id="@+id/tvTime"
            style="@style/TextSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:alpha="0.5"
            android:textSize="10sp"
            tools:text="12:34:56" />

        <LinearLayout
            android:id="@+id/llChatTray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:id="@+id/btnEditChat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_rename"
                app:tint="?attr/primaryColor"
                android:contentDescription="Edit" />

            <View
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <ImageView
                android:id="@+id/btnCopyChat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_copy"
                app:tint="?attr/primaryColor"
                android:contentDescription="@string/copy" />

            <View
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <ImageView
                android:id="@+id/btnDeleteChat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_delete"
                app:tint="#FF4444"
                android:contentDescription="@string/delete" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
