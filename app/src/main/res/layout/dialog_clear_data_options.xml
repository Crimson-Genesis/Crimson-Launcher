<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_rect_shade_color"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/btnClearAllOption"
        style="@style/TextLarge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Clear Tasks &amp; Chat"
        android:textColor="#FF5252"
        android:gravity="center"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/primaryColor"
        android:alpha="0.2" />

    <TextView
        android:id="@+id/btnClearLogsOption"
        style="@style/TextLarge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Clear Progress Logs"
        android:textColor="#FF5252"
        android:gravity="center"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/primaryColor"
        android:alpha="0.2" />

    <TextView
        android:id="@+id/btnCleanSlateOption"
        style="@style/TextLarge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Clean Slate (Reset App)"
        android:textColor="#FF5252"
        android:gravity="center"
        android:textStyle="bold" />

</LinearLayout>
