<resources>
    <style name="DayOfWeekButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/day_of_week_background_selector</item>
        <item name="android:textColor">@color/day_of_week_text_color_selector</item>
        <item name="android:textSize">18sp</item>
        <item name="android:padding">0dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="CustomAlertDialog" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/rounded_rect_shade_color</item>
        <item name="android:textColorPrimary">?attr/primaryColor</item>
    </style>
</resources>
