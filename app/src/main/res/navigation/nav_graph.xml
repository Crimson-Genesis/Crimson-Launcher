<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="app.olauncher.ui.HomeFragment"
        android:label="main_fragment"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_mainFragment_to_appListFragment"
            app:destination="@id/appListFragment" />
        <action
            android:id="@+id/action_mainFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_mainFragment_to_todoFragment"
            app:destination="@id/todoFragment" />
        <action
            android:id="@+id/action_mainFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_mainFragment_to_rightPageFragment"
            app:destination="@id/rightPageFragment" />
    </fragment>

    <fragment
        android:id="@+id/todoFragment"
        android:name="app.olauncher.ui.TodoFragment"
        android:label="TodoFragment"
        tools:layout="@layout/fragment_todo">
        <action
            android:id="@+id/action_todoFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
        <action
            android:id="@+id/action_todoFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_todoFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="app.olauncher.ui.ChatFragment"
        android:label="ChatFragment"
        tools:layout="@layout/fragment_chat">
        <action
            android:id="@+id/action_chatFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
        <action
            android:id="@+id/action_chatFragment_to_todoFragment"
            app:destination="@id/todoFragment" />
        <action
            android:id="@+id/action_chatFragment_to_cameraFragment"
            app:destination="@id/cameraFragment" />
    </fragment>

    <fragment
        android:id="@+id/cameraFragment"
        android:name="app.olauncher.ui.CameraFragment"
        android:label="CameraFragment"
        tools:layout="@layout/fragment_camera" />

    <fragment
        android:id="@+id/rightPageFragment"
        android:name="app.olauncher.ui.RightPageFragment"
        android:label="RightPageFragment"
        tools:layout="@layout/fragment_right_page">
        <action
            android:id="@+id/action_rightPageFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_rightPageFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
    </fragment>

    <fragment
        android:id="@+id/appListFragment"
        android:name="app.olauncher.ui.AppDrawerFragment"
        android:label="app_list_fragment"
        tools:layout="@layout/fragment_app_drawer">
        <action
            android:id="@+id/action_appListFragment_to_settingsFragment2"
            app:destination="@id/settingsFragment"
            app:popUpTo="@+id/appListFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/settingsFragment"
        android:name="app.olauncher.ui.SettingsFragment"
        android:label="SettingsFragment"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settingsFragment_to_rightPageFragment"
            app:destination="@id/rightPageFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_todoFragment"
            app:destination="@id/todoFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_appListFragment"
            app:destination="@id/appListFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_logsFragment"
            app:destination="@id/logsFragment" />
    </fragment>

    <fragment
        android:id="@+id/logsFragment"
        android:name="app.olauncher.ui.LogsFragment"
        android:label="LogsFragment"
        tools:layout="@layout/fragment_logs">
        <action
            android:id="@+id/action_logsFragment_to_logDetailFragment"
            app:destination="@id/logDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/logDetailFragment"
        android:name="app.olauncher.ui.LogDetailFragment"
        android:label="LogDetailFragment"
        tools:layout="@layout/fragment_log_detail">
        <argument
            android:name="logUri"
            app:argType="string" />
        <argument
            android:name="logFileName"
            app:argType="string" />
    </fragment>

</navigation>